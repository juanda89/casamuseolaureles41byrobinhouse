---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../lib/i18n';

const dict = t('es');
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'es' && data.draft === false);
const posts = allPosts.sort((a, b) => +b.data.date_published - +a.data.date_published);

const pathname = '/es/blog';
---
<Base locale="es" title={`${dict.blog.title} · Casa Museo Laureles`} description={dict.blog.metaDescription} pathname={pathname}>
  <header class="container-default pt-12 md:pt-20 pb-10">
    <p class="label-caps text-accent-deep">Blog</p>
    <h1 class="mt-4 font-display font-light text-headline-lg md:text-display-lg text-ink leading-tight max-w-3xl">
      {dict.blog.title.replace('Blog · ', '')}
    </h1>
    <p class="mt-4 max-w-2xl text-ink-muted leading-relaxed text-body-lg">{dict.blog.intro}</p>
  </header>

  <section class="container-default pb-16 md:pb-24">
    {posts.length === 0 ? (
      <p class="text-ink-muted italic text-body">{dict.blog.empty}</p>
    ) : (
      <ul class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <li class="border-t border-ink/10 pt-6">
            <p class="label-caps text-ink-muted">
              {new Date(post.data.date_published).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h2 class="mt-3 font-display font-light text-headline-sm md:text-headline-md text-ink leading-tight">
              <a href={`/es/blog/${post.data.slug}`} class="hover:text-accent-deep transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-3 text-ink-muted leading-relaxed text-body">{post.data.description}</p>
            <a href={`/es/blog/${post.data.slug}`} class="mt-4 inline-block text-accent-deep font-medium hover:underline">
              {dict.blog.readPost}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>
