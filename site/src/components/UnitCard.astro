---
import { t } from '../lib/i18n';
import { UNITS, type UnitSlug } from '../lib/constants';
import type { Locale } from '../lib/constants';

interface Props {
  slug: UnitSlug;
  locale: Locale;
  image: string;
  index?: number;
}
const { slug, locale, image, index = 0 } = Astro.props;
const d = t(locale);
const u = UNITS[slug];
const detailHref = locale === 'es'
  ? `/es/unidades/${u.slug}`
  : `/en/units/${u.enSlug}`;
const bookHref = `${detailHref}#booking`;
const offset = index === 1 ? 'md:translate-y-4' : '';
---
<article class={`group relative flex flex-col rounded-lg bg-surface-warm overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-primary-deep/15 ${offset}`}>
  <a href={detailHref} class="block aspect-[4/5] overflow-hidden bg-surface-sand">
    <img
      src={image}
      alt={`${u.name[locale]} — Casa Museo, Laureles, Medellín`}
      width="800"
      height="1000"
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
    />
  </a>

  {u.highlight && (
    <span class="absolute top-4 left-4 badge badge-gold">
      {u.highlight[locale]}
    </span>
  )}

  <div class="flex flex-col flex-1 p-6 md:p-7 gap-5">
    <header class="flex flex-col gap-2">
      <span class="label-caps text-accent-deep">{u.shortName[locale]}</span>
      <h3 class="font-display font-normal text-headline-md text-ink leading-tight">{u.name[locale]}</h3>
      <p class="text-body-md text-ink-soft">{u.tagline[locale]}</p>
    </header>

    <ul class="flex flex-wrap gap-2">
      <li class="badge badge-leaf">
        <span aria-hidden="true">·</span>
        {u.maxGuests} {u.maxGuests === 1 ? d.bookingBar.guest : d.bookingBar.guestsPlural}
      </li>
      <li class="badge badge-leaf">{u.bed[locale]}</li>
      {u.amenities.slice(0, 2).map((a) => (
        <li class="badge badge-leaf">{a[locale]}</li>
      ))}
    </ul>

    <div class="mt-auto flex items-center justify-between gap-3 pt-3">
      <a href={detailHref} class="btn-ghost !px-0 !text-ink hover:!bg-transparent hover:!text-accent">
        {d.units.viewDetails} →
      </a>
      <a
        href={bookHref}
        data-unit-card-cta
        data-unit={u.slug}
        class="btn-primary !h-11 !px-6 !text-sm"
      >
        {d.units.bookNow}
      </a>
    </div>
  </div>
</article>
