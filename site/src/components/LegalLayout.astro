---
import type { Locale } from '../lib/constants';
interface Props { locale: Locale; eyebrow: string; title: string; updated?: string }
const { locale, eyebrow, title, updated } = Astro.props;
const updatedLabel = locale === 'es' ? 'Actualizado' : 'Updated';
---
<header class="container-default pt-12 md:pt-16 pb-8 max-w-4xl">
  <p class="label-caps text-accent-deep">{eyebrow}</p>
  <h1 class="mt-4 font-display font-light text-headline-lg md:text-display-lg text-ink leading-tight">
    {title}
  </h1>
  {updated && <p class="mt-3 text-body-sm text-ink-soft">{updatedLabel} · {updated}</p>}
</header>
<article class="container-default pb-20 max-w-3xl reading-width prose-style space-y-5 text-body-lg text-ink-soft">
  <slot />
</article>

<style is:global>
  .prose-style h2 { font-family: var(--font-display); font-size: 1.5rem; line-height: 1.25; color: var(--color-ink); margin-top: 2.5rem; }
  .prose-style h3 { font-family: var(--font-display); font-size: 1.125rem; color: var(--color-ink); margin-top: 1.75rem; }
  .prose-style ul { padding-inline-start: 1.5rem; list-style: disc; }
  .prose-style ul li { margin-block: 0.35rem; }
  .prose-style a { color: var(--color-accent); }
  .prose-style a:hover { color: var(--color-accent-deep); text-decoration: underline; text-underline-offset: 4px; }
  .prose-style strong { color: var(--color-ink); }
</style>
