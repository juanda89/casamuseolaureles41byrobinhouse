---
import type { UnitSlug } from '../lib/constants';
import { PHOTOS } from '../lib/photos';
import { UNITS } from '../lib/constants';
import type { Locale } from '../lib/constants';

interface Props { slug: UnitSlug; locale: Locale }
const { slug, locale } = Astro.props;
const photos = PHOTOS[slug].gallery;
const name = UNITS[slug].name[locale];
---
<section class="container-default py-16 md:py-20">
  <div class="grid gap-3 md:gap-4 md:grid-cols-3">
    {photos.map((p, i) => (
      <a
        href={p.full}
        target="_blank"
        rel="noopener"
        class={`block overflow-hidden rounded-lg bg-surface-warm aspect-[4/5] ${i === 0 ? 'md:col-span-2 md:row-span-2 md:aspect-[5/6]' : ''}`}
      >
        <img
          src={p.large}
          alt={`${name} — Casa Museo, Laureles`}
          loading={i < 2 ? 'eager' : 'lazy'}
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-700 hover:scale-[1.03]"
        />
      </a>
    ))}
  </div>
</section>
