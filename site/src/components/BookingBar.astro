---
import { t } from '../lib/i18n';
import { UNITS, UNIT_ORDER, NAP } from '../lib/constants';
import { defaultRange } from '../lib/booking';
import type { Locale } from '../lib/constants';

interface Props {
  locale: Locale;
  variant?: 'hero' | 'inline';
  preselectedUnit?: keyof typeof UNITS;
}
const { locale, variant = 'hero', preselectedUnit } = Astro.props;
const d = t(locale);
const { start, end } = defaultRange();
const today = new Date().toISOString().slice(0, 10);

const unitOptions = UNIT_ORDER.map((slug) => ({
  slug,
  id: UNITS[slug].id,
  label: UNITS[slug].name[locale],
  cap: UNITS[slug].maxGuests,
}));
---
<form
  id={`booking-form-${variant}`}
  data-booking-form
  data-locale={locale}
  data-whatsapp={NAP.whatsapp}
  data-error-dates={d.bookingBar.errorDates}
  data-too-many={d.bookingBar.tooManyGuests}
  class={`rounded-lg bg-surface/95 backdrop-blur p-4 md:p-5 shadow-2xl shadow-primary-deep/30 grid gap-3 md:grid-cols-[1fr_1fr_auto_1.4fr_auto] md:items-end ${variant === 'hero' ? '' : 'border border-outline-soft'}`}
>
  <label class="flex flex-col gap-1.5">
    <span class="label-caps text-ink-mute">{d.bookingBar.checkin}</span>
    <input type="date" name="start" min={today} value={start} required class="input-field font-numeric" />
  </label>
  <label class="flex flex-col gap-1.5">
    <span class="label-caps text-ink-mute">{d.bookingBar.checkout}</span>
    <input type="date" name="end" min={today} value={end} required class="input-field font-numeric" />
  </label>
  <label class="flex flex-col gap-1.5">
    <span class="label-caps text-ink-mute">{d.bookingBar.guests}</span>
    <select name="numberOfGuests" class="input-field" required>
      <option value="1">1 {d.bookingBar.guest}</option>
      <option value="2" selected>2 {d.bookingBar.guestsPlural}</option>
      <option value="3">3 {d.bookingBar.guestsPlural}</option>
      <option value="4">4 {d.bookingBar.guestsPlural}</option>
      <option value="5">5+ {d.bookingBar.guestsPlural}</option>
    </select>
  </label>
  <label class="flex flex-col gap-1.5">
    <span class="label-caps text-ink-mute">{d.bookingBar.unit}</span>
    <select name="unit" class="input-field">
      <option value="any" selected={!preselectedUnit}>{d.bookingBar.anyUnit}</option>
      {unitOptions.map((u) => (
        <option value={u.slug} selected={preselectedUnit === u.slug}>{u.label} · {u.cap}p</option>
      ))}
    </select>
  </label>
  <button type="submit" class="btn-primary w-full md:w-auto md:!px-10">{d.bookingBar.submit}</button>

  <div class="md:col-span-5">
    <p data-booking-error class="hidden text-body-sm text-error" role="alert"></p>
    <p class="mt-1 text-body-sm text-ink-mute">{d.bookingBar.fiscalNote}</p>
  </div>
</form>

<script is:inline>
  (function () {
    const UNITS = { standar: 485562, familiar: 486242, deluxe: 489587 };
    document.querySelectorAll('[data-booking-form]').forEach((form) => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        let unit = String(fd.get('unit') || 'any');
        const start = String(fd.get('start') || '');
        const end = String(fd.get('end') || '');
        const guestsRaw = fd.get('numberOfGuests');
        const guests = parseInt(String(guestsRaw || '2'), 10);
        const errBox = form.querySelector('[data-booking-error]');
        const errMsgDates = form.dataset.errorDates || 'Invalid dates';
        const errTooMany = form.dataset.tooMany || 'Too many guests';
        const showErr = (msg) => {
          if (!errBox) return;
          errBox.textContent = msg;
          errBox.classList.remove('hidden');
        };

        if (!start || !end || new Date(end) <= new Date(start)) {
          showErr(errMsgDates);
          return;
        }

        // 5+ guests → WhatsApp
        if (guests >= 5) {
          const wa = form.dataset.whatsapp;
          const text = encodeURIComponent(
            (form.dataset.locale === 'en'
              ? `Hi! We are ${guests} guests for Casa Laureles 41 from ${start} to ${end}. Could you help us combine units?`
              : `Hola! Somos ${guests} huéspedes y queremos hospedarnos en Casa Laureles 41 del ${start} al ${end}. ¿Pueden ayudarnos a combinar unidades?`)
          );
          window.open(`https://wa.me/${wa}?text=${text}`, '_blank', 'noopener');
          if (window.gtag) window.gtag('event', 'booking_intent', { unit: 'whatsapp_overflow', start, end, numberOfGuests: guests });
          return;
        }

        // Auto-select
        if (unit === 'any') {
          unit = guests >= 3 ? 'familiar' : 'standar';
        }
        if (!UNITS[unit]) {
          showErr(errMsgDates);
          return;
        }
        // Capacity guard for chosen unit
        const caps = { standar: 2, familiar: 4, deluxe: 2 };
        if (guests > caps[unit]) {
          unit = guests >= 3 ? 'familiar' : 'standar';
        }

        if (window.gtag) window.gtag('event', 'booking_intent', { unit, start, end, numberOfGuests: guests });
        const url = `https://booking.housyhost.com/listings/${UNITS[unit]}?start=${start}&end=${end}&numberOfGuests=${guests}`;
        window.open(url, '_blank', 'noopener');
      });
    });
  })();
</script>
