---
import { t } from '../lib/i18n';
import type { Locale } from '../lib/constants';
import { PARENT } from '../lib/constants';
interface Props { locale: Locale; image?: string }
const { locale, image } = Astro.props;
const d = t(locale);
const detailImg = image ?? '/img/hero/concept-detail.webp';
const alt = locale === 'es'
  ? 'Detalle de diseño en Casa Museo: piedra tallada, madera y luz cálida'
  : 'Casa Museo design detail: carved stone, oak and warm light';
---
<section class="container-default py-24 md:py-32">
  <hr class="divider-gold mb-16" />
  <div class="grid gap-12 md:gap-20 md:grid-cols-12 items-center">
    <div class="md:col-span-5 lg:col-span-4">
      <p class="label-caps text-accent-deep">{d.concept.eyebrow}</p>
      <h2 class="mt-5 font-display font-normal text-headline-lg md:text-display-lg text-ink leading-tight">
        {d.concept.title}
      </h2>
      <p class="mt-6 text-body-lg text-ink-soft reading-width">{d.concept.body}</p>
      <p class="mt-8 text-body-sm text-ink-soft">
        {d.concept.designerLabel}
        <a href={PARENT.url} target="_blank" rel="noopener" class="ml-1.5 inline-flex items-center text-accent hover:text-accent-deep transition-colors underline-offset-4 hover:underline">
          {d.concept.designerName} →
        </a>
      </p>
    </div>
    <figure class="md:col-span-7 lg:col-span-8 relative">
      <div class="relative overflow-hidden rounded-lg">
        <img
          src={detailImg}
          alt={alt}
          width="1024"
          height="700"
          loading="lazy"
          decoding="async"
          class="w-full aspect-[4/3] object-cover"
        />
      </div>
      <figcaption class="mt-3 label-caps text-ink-soft">
        {locale === 'es' ? 'Casa Museo · Laureles, Medellín' : 'Casa Museo · Laureles, Medellín'}
      </figcaption>
    </figure>
  </div>
</section>
