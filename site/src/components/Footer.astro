---
import { t } from '../lib/i18n';
import { NAP, PARENT, SITE, SOCIAL } from '../lib/constants';
import type { Locale } from '../lib/constants';

interface Props { locale: Locale }
const { locale } = Astro.props;
const d = t(locale);
const home = locale === 'es' ? '/es' : '/en';
const exploreLinks = locale === 'es'
  ? [
      { href: '/es#unidades', label: d.nav.units },
      { href: '/es/laureles', label: d.nav.neighborhood },
      { href: '/es/faq', label: d.nav.faq },
      { href: '/es/contacto', label: d.nav.contact },
    ]
  : [
      { href: '/en#units', label: d.nav.units },
      { href: '/en/laureles', label: d.nav.neighborhood },
      { href: '/en/faq', label: d.nav.faq },
      { href: '/en/contact', label: d.nav.contact },
    ];
const legalLinks = locale === 'es'
  ? [
      { href: '/es/privacidad', label: d.footer.privacy },
      { href: '/es/terminos', label: d.footer.terms },
      { href: '/es/cancelacion', label: d.footer.cancellation },
      { href: '/es/cookies', label: d.footer.cookies },
    ]
  : [
      { href: '/en/privacy', label: d.footer.privacy },
      { href: '/en/terms', label: d.footer.terms },
      { href: '/en/cancellation', label: d.footer.cancellation },
      { href: '/en/cookies', label: d.footer.cookies },
    ];

const year = new Date().getFullYear();
---
<footer class="bg-primary-deep text-on-primary mt-24">
  <div class="container-default py-16 md:py-20 grid gap-12 md:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-1">
      <a href={home} class="font-display text-2xl font-light tracking-tight text-on-primary">Casa Museo</a>
      <p class="mt-3 text-body-md text-surface-sand/85 max-w-xs">{d.footer.tagline}</p>
      <p class="mt-6 text-body-sm text-surface-sand/80">
        {d.footer.operated} · {d.footer.designed}
        <a href={PARENT.url} class="text-gold hover:text-gold-soft underline underline-offset-4 decoration-gold/50 hover:decoration-gold transition-colors" target="_blank" rel="noopener">{PARENT.name}</a>
        <a href={PARENT.instagramUrl} target="_blank" rel="noopener" aria-label="Instagram de Robin House" class="ml-1.5 inline-flex align-middle text-gold/70 hover:text-gold transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
        </a>.
      </p>
    </div>

    <div>
      <h3 class="label-caps text-gold">{d.footer.address}</h3>
      <address class="mt-4 not-italic text-body-md text-surface-sand">
        {NAP.streetAddress}<br />
        {NAP.neighborhood[locale]}<br />
        {NAP.locality}, {NAP.region}<br />
        {NAP.countryName[locale]}
      </address>
      <a href={NAP.gmapsUrl} class="inline-block mt-3 text-body-sm text-gold hover:text-gold-soft transition-colors" target="_blank" rel="noopener">Google Maps →</a>
    </div>

    <div>
      <h3 class="label-caps text-gold">{d.footer.contact}</h3>
      <ul class="mt-4 space-y-3 text-body-md text-surface-sand">
        <li><a href={`https://wa.me/${NAP.whatsapp}`} class="hover:text-gold transition-colors" target="_blank" rel="noopener">WhatsApp · {NAP.phoneDisplay}</a></li>
        <li><a href={`tel:${NAP.phone}`} class="hover:text-gold transition-colors">Tel · {NAP.phoneDisplay}</a></li>
        <li><a href={`mailto:${NAP.email}`} class="hover:text-gold transition-colors">{NAP.email}</a></li>
        <li>
          <a
            href={SOCIAL.instagramUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 hover:text-gold transition-colors"
            aria-label={`Instagram @${SOCIAL.instagram}`}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
            </svg>
            Instagram · @{SOCIAL.instagram}
          </a>
        </li>
      </ul>
    </div>

    <div class="grid grid-cols-2 gap-8">
      <div>
        <h3 class="label-caps text-gold">{d.footer.explore}</h3>
        <ul class="mt-4 space-y-2 text-body-md text-surface-sand">
          {exploreLinks.map((l) => (<li><a href={l.href} class="hover:text-gold transition-colors">{l.label}</a></li>))}
        </ul>
      </div>
      <div>
        <h3 class="label-caps text-gold">{d.footer.legal}</h3>
        <ul class="mt-4 space-y-2 text-body-md text-surface-sand">
          {legalLinks.map((l) => (<li><a href={l.href} class="hover:text-gold transition-colors">{l.label}</a></li>))}
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-on-primary/15">
    <div class="container-default py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-body-sm text-surface-sand/80">
      <p>© {year} Casa Laureles 41 · {d.footer.rights}</p>
      <p class="font-numeric tracking-wide">{NAP.geo.lat.toFixed(6)}, {NAP.geo.lng.toFixed(6)}</p>
    </div>
  </div>
</footer>
